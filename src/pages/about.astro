---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/sections/PageHero.astro";
import SplitSection from "@/components/sections/SplitSection.astro";
import StatsRow from "@/components/sections/StatsRow.astro";
import ProcessGrid from "@/components/sections/ProcessGrid.astro";
import ReviewsGrid from "@/components/sections/ReviewsGrid.astro";
import CTASection from "@/components/sections/CTASection.astro";
import QuoteSection from "@/components/sections/QuoteSection.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Container from "@/components/ui/Container.astro";
import { businessConfig } from "@/config/business";
import { aboutContent } from "@/config/about";
import { aboutStats } from "@/config/stats";
import { featuredReviews } from "@/config/reviews";
import { generatePageMetadata } from "@/lib/metadata";
import { generateBreadcrumbSchema } from "@/lib/structured-data";

// Reuse the legacy H1 from the old site.
const aboutHeading = "About River Creek";

const meta = generatePageMetadata({
  title: "About River Creek Fence | Haven, KS Fence Company",
  description:
    "River Creek Fence is a Central Kansas fence company built on real farm experience and word of mouth. Learn how owner Cody Yoder and his crew build fencing that holds up across Reno County.",
  path: "/about",
});

const phoneCta = {
  label: `Call ${businessConfig.phone}`,
  href: `tel:${businessConfig.phoneRaw}`,
};

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", href: "/" },
  { name: aboutHeading, href: "/about" },
]);
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  ogTitle={meta.ogTitle}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  <PageHero
    heading={aboutHeading}
    subtitle={aboutContent.hero.subtitle}
    imageKey="about-hero"
    breadcrumbs={[{ label: "Home", href: "/" }, { label: aboutHeading }]}
    primaryCta={{ label: "Get a Free Quote", href: "/contact" }}
    secondaryCta={phoneCta}
  />

  <SplitSection
    imageKey={aboutContent.story.image}
    imagePosition="left"
    imageAspect="3/4"
  >
    <SectionHeading
      eyebrow={aboutContent.story.eyebrow}
      heading={aboutContent.story.heading}
    />
    {
      aboutContent.story.paragraphs.map((p) => (
        <p class="mb-4 text-base leading-relaxed text-muted md:text-lg">{p}</p>
      ))
    }
  </SplitSection>

  <StatsRow stats={aboutStats} bgColor="primary" />

  <section class="section-padding">
    <Container>
      <SectionHeading
        eyebrow={aboutContent.values.eyebrow}
        heading={aboutContent.values.heading}
        align="center"
      />
      <div class="grid gap-6 md:grid-cols-2">
        {
          aboutContent.values.items.map((item) => (
            <div class="rounded-2xl border border-border bg-white p-6 md:p-8">
              <h3 class="text-lg font-bold text-foreground">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <SplitSection
    imageKey={aboutContent.team.image}
    imagePosition="right"
    bgColor="surface"
    imageAspect="4/3"
  >
    <SectionHeading
      eyebrow={aboutContent.team.eyebrow}
      heading={aboutContent.team.heading}
    />
    {
      aboutContent.team.paragraphs.map((p) => (
        <p class="mb-4 text-base leading-relaxed text-muted md:text-lg">{p}</p>
      ))
    }
  </SplitSection>

  <ProcessGrid
    eyebrow="How It Works"
    heading="Getting a Fence Should Be Simple"
    subtitle="The same straightforward process on every job, big or small."
    primaryCta={{ label: "Get a Free Quote", href: "/contact" }}
    secondaryCta={phoneCta}
  />

  <ReviewsGrid items={featuredReviews} bgColor="surface" />

  <CTASection
    heading="Let's Build Something That Lasts"
    text="Start with a free, no-pressure estimate. We'll walk your property and give you an honest quote."
    primaryCta={{ label: "Get a Free Quote", href: "/contact" }}
    secondaryCta={{ label: "View Our Services", href: "/services" }}
  />

  <QuoteSection />
</Layout>
