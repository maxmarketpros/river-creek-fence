---
import { ArrowRight, Phone, ArrowUpRight } from "lucide-react";
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/sections/PageHero.astro";
import SpecBar from "@/components/sections/SpecBar.astro";
import SplitSection from "@/components/sections/SplitSection.astro";
import ProsCons from "@/components/sections/ProsCons.astro";
import UseCaseGrid from "@/components/sections/UseCaseGrid.astro";
import TypeGallery from "@/components/sections/TypeGallery.astro";
import CostSnapshot from "@/components/sections/CostSnapshot.astro";
import BuildSteps from "@/components/sections/BuildSteps.astro";
import FAQSection from "@/components/sections/FAQSection.astro";
import CTASection from "@/components/sections/CTASection.astro";
import QuoteSection from "@/components/sections/QuoteSection.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import { propertyConfigs } from "@/config/property";
import { businessConfig } from "@/config/business";
import { getHeroPreload } from "@/config/images";
import { generatePageMetadata } from "@/lib/metadata";
import {
  generateFenceTypeSchema,
  generateBreadcrumbSchema,
} from "@/lib/structured-data";
import type { FenceTypeConfig } from "@/types";

export async function getStaticPaths() {
  return propertyConfigs.map((config) => ({
    params: { slug: config.slug },
    props: { config },
  }));
}

interface Props {
  config: FenceTypeConfig;
}

const { config } = Astro.props as Props;

const ctaProps = {
  primary: { label: "Get a Free Quote", href: "/contact" },
  secondary: {
    label: `Call ${businessConfig.phone}`,
    href: `tel:${businessConfig.phoneRaw}`,
  },
};

const meta = generatePageMetadata({
  title: config.metaTitle,
  description: config.excerpt,
  path: `/property/${config.slug}`,
});

const serviceSchema = generateFenceTypeSchema(config, "property");
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", href: "/" },
  { name: "Services", href: "/services" },
  { name: config.title, href: `/property/${config.slug}` },
]);

const faqItems = config.faqs.map((f, i) => ({
  id: `${config.slug}-faq-${i}`,
  question: f.question,
  answer: f.answer,
}));

const showGallery = !!config.gallery && config.gallery.length >= 4;
const heroPreload = await getHeroPreload(`${config.slug}-hero`);
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  ogTitle={meta.ogTitle}
  preloadImage={heroPreload}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(serviceSchema)}
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  {/* Hero */}
  <PageHero
    heading={config.h1}
    subtitle={config.excerpt}
    imageKey={`${config.slug}-hero`}
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "Services", href: "/services" },
      { label: config.title },
    ]}
    primaryCta={ctaProps.primary}
    secondaryCta={ctaProps.secondary}
  />

  {/* At-a-glance specs */}
  <SpecBar items={config.atAGlance} />

  {/* Overview (content image #1: `${slug}-b`) */}
  <SplitSection
    imageKey={`${config.slug}-b`}
    imagePosition="right"
    imageAspect="4/3"
  >
    <SectionHeading eyebrow="Overview" heading={config.overviewHeading} />
    {
      config.description.map((p) => (
        <p class="mb-4 text-base leading-relaxed text-muted md:text-lg">{p}</p>
      ))
    }
    <div class="mt-6 flex flex-wrap gap-4">
      <Button href="/contact">
        Get a Free Quote
        <ArrowRight slot="icon" className="h-5 w-5" />
      </Button>
      <Button href={`tel:${businessConfig.phoneRaw}`} variant="outline">
        {businessConfig.phone}
        <Phone slot="icon" className="h-5 w-5" />
      </Button>
    </div>
  </SplitSection>

  {/* Pros & considerations */}
  <ProsCons
    heading={config.prosConsHeading}
    pros={config.pros}
    considerations={config.considerations}
    bgColor="surface"
  />

  {/* Feature (content image #2: `${slug}-a`) */}
  <SplitSection
    imageKey={`${config.slug}-a`}
    imagePosition="left"
    imageAspect="4/3"
  >
    <SectionHeading eyebrow="Built to Last" heading={config.featureHeading} />
    {
      config.featureBody.map((p) => (
        <p class="mb-4 text-base leading-relaxed text-muted md:text-lg">{p}</p>
      ))
    }
  </SplitSection>

  {/* Where this fits (internal links) */}
  <UseCaseGrid section={config.useCases} bgColor="surface" />

  {/* Per-type gallery (only when enough matching photos exist) */}
  {
    showGallery && (
      <TypeGallery
        imageNumbers={config.gallery!}
        heading={config.galleryHeading ?? `Recent ${config.title} Projects`}
        altSubject={config.title}
      />
    )
  }

  {/* Cost snapshot */}
  <CostSnapshot
    cost={config.costSnapshot}
    title={config.title}
    class={showGallery ? "bg-surface" : ""}
  />

  {/* How we build it */}
  <BuildSteps
    heading={config.buildStepsHeading}
    steps={config.buildSteps}
    bgColor={showGallery ? "white" : "surface"}
  />

  {/* FAQ (emits FAQPage schema) */}
  <FAQSection
    eyebrow="Common Questions"
    heading={`${config.title} FAQ`}
    items={faqItems}
    bgColor={showGallery ? "surface" : "white"}
  />

  {/* Related links */}
  {
    config.related.length > 0 && (
      <section class="section-padding-sm">
        <Container>
          <h2 class="mb-6 text-xl font-bold text-foreground">
            Related services &amp; resources
          </h2>
          <div class="flex flex-wrap gap-3">
            {config.related.map((link) => (
              <a
                href={link.href}
                class="inline-flex items-center gap-1.5 rounded-full border border-border bg-white px-4 py-2 text-sm font-medium text-foreground-light transition-colors hover:border-primary-500 hover:text-primary-700"
              >
                {link.label}
                <ArrowUpRight className="h-4 w-4 text-primary-700" />
              </a>
            ))}
          </div>
        </Container>
      </section>
    )
  }

  {/* CTA */}
  <CTASection
    heading={config.ctaHeading}
    text={config.ctaText}
    primaryCta={ctaProps.primary}
    secondaryCta={ctaProps.secondary}
  />

  {/* Quote Form */}
  <QuoteSection />
</Layout>
