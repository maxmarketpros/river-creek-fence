---
import { ArrowUpRight } from "lucide-react";
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/sections/PageHero.astro";
import CTASection from "@/components/sections/CTASection.astro";
import QuoteSection from "@/components/sections/QuoteSection.astro";
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import ServiceCard from "@/components/ui/ServiceCard.astro";
import { services } from "@/config/services";
import {
  fenceTypes,
  propertyPages,
  materials,
  fenceTypesBase,
  propertyBase,
  materialsBase,
} from "@/config/catalog";
import { businessConfig } from "@/config/business";
import { generatePageMetadata } from "@/lib/metadata";
import { generateBreadcrumbSchema } from "@/lib/structured-data";

const meta = generatePageMetadata({
  title: "Fencing Services in Central Kansas | River Creek Fence",
  description:
    "Explore every fence service from River Creek Fence — installation, repair, residential, farm, ranch, and commercial fencing, plus fence types and gates across Reno County and Central Kansas.",
  path: "/services",
});

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", href: "/" },
  { name: "Services", href: "/services" },
]);

const linkGroups = [
  { title: "Fence Types", subtitle: "From cedar privacy to barbed wire — built for how you use your property.", items: fenceTypes, base: fenceTypesBase },
  { title: "Property & Animal Fencing", subtitle: "Fencing designed around your animals, acreage, and the way you work your land.", items: propertyPages, base: propertyBase },
  { title: "Fence Materials (Coming Soon)", subtitle: "We're expanding into materials and supplies for Central Kansas farms, ranches, and homeowners.", items: materials, base: materialsBase },
];
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  ogTitle={meta.ogTitle}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  <PageHero
    heading="Our Fencing Services"
    subtitle="Residential, farm, ranch, and commercial fencing — installed and repaired right, across Reno County and Central Kansas."
    imageKey="stock-1"
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Services" }]}
    primaryCta={{ label: "Get a Free Quote", href: "/contact" }}
    secondaryCta={{
      label: `Call ${businessConfig.phone}`,
      href: `tel:${businessConfig.phoneRaw}`,
    }}
  />

  {/* Core services */}
  <section class="section-padding">
    <Container>
      <SectionHeading
        eyebrow="Core Services"
        heading="What We Do"
        subtitle="The fencing work we handle most across Central Kansas."
        align="center"
      />
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </Container>
  </section>

  {/* Link groups */}
  {
    linkGroups.map((group, i) => (
      <section class={i % 2 === 0 ? "section-padding bg-surface" : "section-padding"}>
        <Container>
          <SectionHeading
            eyebrow="Explore"
            heading={group.title}
            subtitle={group.subtitle}
            align="center"
          />
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {group.items.map((item) => (
              <a
                href={`${group.base}/${item.slug}`}
                class="group flex items-center justify-between gap-3 rounded-xl border border-border bg-white px-5 py-4 shadow-card transition-all hover:-translate-y-0.5 hover:border-primary-500 hover:shadow-card-hover"
              >
                <span class="font-semibold text-foreground group-hover:text-primary-700">
                  {item.title}
                </span>
                <ArrowUpRight className="h-5 w-5 shrink-0 text-primary-700" />
              </a>
            ))}
          </div>
        </Container>
      </section>
    ))
  }

  <CTASection
    heading="Not Sure Which Fence Is Right?"
    text="Tell us about your property and we'll recommend the best fit — then give you a free, honest estimate."
    primaryCta={{ label: "Get a Free Quote", href: "/contact" }}
    secondaryCta={{ label: "Browse Service Areas", href: "/service-areas" }}
  />

  <QuoteSection />
</Layout>
