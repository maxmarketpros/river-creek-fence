---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/sections/PageHero.astro";
import CTASection from "@/components/sections/CTASection.astro";
import QuoteSection from "@/components/sections/QuoteSection.astro";
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import ServiceCard from "@/components/ui/ServiceCard.astro";
import LinkCard from "@/components/ui/LinkCard.astro";
import { services } from "@/config/services";
import { fenceTypeConfigs } from "@/config/fence-types";
import { propertyConfigs } from "@/config/property";
import { materialsConfigs } from "@/config/materials";
import { fenceTypesBase, propertyBase, materialsBase } from "@/config/catalog";
import { businessConfig } from "@/config/business";
import { generatePageMetadata } from "@/lib/metadata";
import { generateBreadcrumbSchema } from "@/lib/structured-data";

const meta = generatePageMetadata({
  title: "Fencing Services in Central Kansas | River Creek Fence",
  description:
    "Explore every fence service from River Creek Fence — installation, repair, residential, farm, ranch, and commercial fencing, plus fence types and gates across Reno County and Central Kansas.",
  path: "/services",
});

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", href: "/" },
  { name: "Services", href: "/services" },
]);

const linkGroups = [
  { title: "Fence Types", subtitle: "From cedar privacy to barbed wire — built for how you use your property.", items: fenceTypeConfigs, base: fenceTypesBase },
  { title: "Property & Animal Fencing", subtitle: "Fencing designed around your animals, acreage, and the way you work your land.", items: propertyConfigs, base: propertyBase },
  { title: "Fence Materials", subtitle: "Quality fence materials and supplies for Central Kansas farms, ranches, and homeowners — wire, posts, pipe, gates, and hardware for your project.", items: materialsConfigs, base: materialsBase },
];
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  ogTitle={meta.ogTitle}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  <PageHero
    heading="Our Fencing Services"
    subtitle="Residential, farm, ranch, and commercial fencing — installed and repaired right, across Reno County and Central Kansas."
    imageKey="stock-1"
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Services" }]}
    primaryCta={{ label: "Get a Free Quote", href: "/contact" }}
    secondaryCta={{
      label: `Call ${businessConfig.phone}`,
      href: `tel:${businessConfig.phoneRaw}`,
    }}
  />

  {/* Core services */}
  <section class="section-padding">
    <Container>
      <SectionHeading
        eyebrow="Core Services"
        heading="What We Do"
        subtitle="The fencing work we handle most across Central Kansas."
        align="center"
      />
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </Container>
  </section>

  {/* Link groups */}
  {
    linkGroups.map((group, i) => (
      <section class={i % 2 === 0 ? "section-padding bg-surface" : "section-padding"}>
        <Container>
          <SectionHeading
            eyebrow="Explore"
            heading={group.title}
            subtitle={group.subtitle}
            align="center"
          />
          <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {group.items.map((item) => (
              <LinkCard
                href={`${group.base}/${item.slug}`}
                title={item.title}
                description={item.excerpt}
                imageKey={`${item.slug}-a`}
                icon={item.icon}
              />
            ))}
          </div>
        </Container>
      </section>
    ))
  }

  <CTASection
    heading="Not Sure Which Fence Is Right?"
    text="Tell us about your property and we'll recommend the best fit — then give you a free, honest estimate."
    primaryCta={{ label: "Get a Free Quote", href: "/contact" }}
    secondaryCta={{ label: "Browse Service Areas", href: "/service-areas" }}
  />

  <QuoteSection />
</Layout>
