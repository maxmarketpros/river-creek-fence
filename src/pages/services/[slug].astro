---
import { ArrowRight, Phone, ArrowUpRight } from "lucide-react";
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/sections/PageHero.astro";
import SplitSection from "@/components/sections/SplitSection.astro";
import BenefitGrid from "@/components/sections/BenefitGrid.astro";
import ServiceScopeSection from "@/components/sections/ServiceScopeSection.astro";
import TopicCardGrid from "@/components/sections/TopicCardGrid.astro";
import FAQSection from "@/components/sections/FAQSection.astro";
import CTASection from "@/components/sections/CTASection.astro";
import QuoteSection from "@/components/sections/QuoteSection.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import { services } from "@/config/services";
import { businessConfig } from "@/config/business";
import { getHeroPreload } from "@/config/images";
import { generatePageMetadata } from "@/lib/metadata";
import {
  generateServiceSchema,
  generateBreadcrumbSchema,
} from "@/lib/structured-data";
import type { ServiceConfig } from "@/types";

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Props {
  service: ServiceConfig;
}

const { service } = Astro.props as Props;

const ctaProps = {
  primary: { label: "Get a Free Quote", href: "/contact" },
  secondary: {
    label: `Call ${businessConfig.phone}`,
    href: `tel:${businessConfig.phoneRaw}`,
  },
};

const meta = generatePageMetadata({
  title: service.metaTitle,
  description: service.excerpt,
  path: `/services/${service.slug}`,
});

const serviceSchema = generateServiceSchema(service);
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", href: "/" },
  { name: "Services", href: "/services" },
  { name: service.title, href: `/services/${service.slug}` },
]);

const faqItems = service.faqs.map((f, i) => ({
  id: `${service.slug}-faq-${i}`,
  question: f.question,
  answer: f.answer,
}));

const heroPreload = await getHeroPreload(`${service.slug}-hero`);
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  ogTitle={meta.ogTitle}
  preloadImage={heroPreload}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(serviceSchema)}
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  {/* Hero */}
  <PageHero
    heading={service.h1}
    subtitle={service.excerpt}
    imageKey={`${service.slug}-hero`}
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "Services", href: "/services" },
      { label: service.title },
    ]}
    primaryCta={ctaProps.primary}
    secondaryCta={ctaProps.secondary}
  />

  {/* Overview (content image #1: `${slug}-b`) */}
  <SplitSection
    imageKey={`${service.slug}-b`}
    imagePosition="right"
    imageAspect="4/3"
  >
    <SectionHeading eyebrow="Overview" heading={service.overviewHeading} />
    {
      service.description.map((p) => (
        <p class="mb-4 text-base leading-relaxed text-muted md:text-lg">{p}</p>
      ))
    }
    <div class="mt-6 flex flex-wrap gap-4">
      <Button href="/contact">
        Get a Free Quote
        <ArrowRight slot="icon" className="h-5 w-5" />
      </Button>
      <Button href={`tel:${businessConfig.phoneRaw}`} variant="outline">
        {businessConfig.phone}
        <Phone slot="icon" className="h-5 w-5" />
      </Button>
    </div>
  </SplitSection>

  {/* Benefits */}
  <BenefitGrid
    benefits={service.benefits}
    eyebrow="Why River Creek Fence"
    heading={service.benefitsHeading}
    subtitle={service.benefitsSubtitle}
    bgColor="surface"
  />

  {/* SEO Topic Section A */}
  <TopicCardGrid
    eyebrow={service.topicSectionA.eyebrow}
    heading={service.topicSectionA.heading}
    subtitle={service.topicSectionA.subtitle}
    items={service.topicSectionA.items}
  />

  {/* Feature (content image #2: `${slug}-a`) */}
  <SplitSection
    imageKey={`${service.slug}-a`}
    imagePosition="left"
    imageAspect="4/3"
    bgColor="surface"
  >
    <SectionHeading eyebrow="Built to Last" heading={service.featureHeading} />
    {
      service.featureBody.map((p) => (
        <p class="mb-4 text-base leading-relaxed text-muted md:text-lg">{p}</p>
      ))
    }
  </SplitSection>

  {/* What's Included */}
  <ServiceScopeSection
    items={service.features}
    heading={service.scopeHeading}
    subtitle={service.scopeIntro}
    primaryCta={ctaProps.primary}
    secondaryCta={ctaProps.secondary}
  />

  {/* SEO Topic Section B */}
  <TopicCardGrid
    eyebrow={service.topicSectionB.eyebrow}
    heading={service.topicSectionB.heading}
    subtitle={service.topicSectionB.subtitle}
    items={service.topicSectionB.items}
    bgColor="surface"
  />

  {/* FAQ */}
  <FAQSection
    eyebrow="Common Questions"
    heading={`${service.title} FAQ`}
    items={faqItems}
  />

  {/* Related links */}
  {
    service.related.length > 0 && (
      <section class="section-padding-sm">
        <Container>
          <h2 class="mb-6 text-xl font-bold text-foreground">
            Related services & resources
          </h2>
          <div class="flex flex-wrap gap-3">
            {service.related.map((link) => (
              <a
                href={link.href}
                class="inline-flex items-center gap-1.5 rounded-full border border-border bg-white px-4 py-2 text-sm font-medium text-foreground-light transition-colors hover:border-primary-500 hover:text-primary-700"
              >
                {link.label}
                <ArrowUpRight className="h-4 w-4 text-primary-700" />
              </a>
            ))}
          </div>
        </Container>
      </section>
    )
  }

  {/* CTA */}
  <CTASection
    heading={service.ctaHeading}
    text={service.ctaText}
    primaryCta={ctaProps.primary}
    secondaryCta={ctaProps.secondary}
  />

  {/* Quote Form */}
  <QuoteSection />
</Layout>
