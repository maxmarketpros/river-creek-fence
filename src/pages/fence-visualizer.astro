---
import { ChevronRight, ArrowRight } from "lucide-react";
import Layout from "@/layouts/Layout.astro";
import CTASection from "@/components/sections/CTASection.astro";
import QuoteSection from "@/components/sections/QuoteSection.astro";
import FAQSection from "@/components/sections/FAQSection.astro";
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import { businessConfig } from "@/config/business";
import { generatePageMetadata } from "@/lib/metadata";
import { generateBreadcrumbSchema } from "@/lib/structured-data";
import type { FAQItem } from "@/types";

const VISUALIZER_URL = "https://fence-visions-ai.lovable.app/";
const VISUALIZER_ORIGIN = new URL(VISUALIZER_URL).origin;

const meta = generatePageMetadata({
  title: "AI Fence Visualizer — Preview Your New Fence | River Creek Fence",
  description:
    "Try River Creek Fence's free AI fence visualizer — upload a photo of your yard, preview cedar privacy, vinyl, chain link, and ranch fence styles, then get a free estimate. Serving Haven, Hutchinson & Central Kansas.",
  path: "/fence-visualizer",
});

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", href: "/" },
  { name: "Fence Visualizer", href: "/fence-visualizer" },
]);

const styles = [
  { label: "Cedar Privacy", href: "/fence-types/cedar-privacy-fence-installation" },
  { label: "Vinyl Privacy", href: "/fence-types/vinyl-fence-installation" },
  { label: "Chain Link", href: "/fence-types/chain-link-fence-installation" },
  { label: "Wrought Iron", href: "/fence-types/wrought-iron-fence-installation" },
  { label: "Ranch Rail", href: "/fence-types/wood-ranch-rail-fencing" },
  { label: "Woven Wire", href: "/fence-types/woven-wire-fence-installation" },
  { label: "Barbed Wire", href: "/fence-types/barbed-wire-fence-installation" },
  { label: "Ornamental Metal", href: "/fence-types/metal-fence-installation" },
];

const visualizerFaqs: FAQItem[] = [
  {
    id: "visualizer-how",
    question: "How does the fence visualizer work?",
    answer:
      "Upload a photo of your yard (or use the demo image), pick a fence style, and the AI tool generates a realistic preview of that fence on your property. It's a fast way to compare styles and colors before you commit — no sales pressure, no obligation.",
  },
  {
    id: "visualizer-free",
    question: "Is the fence visualizer free to use?",
    answer:
      "Yes — it's completely free and there's no obligation. Try as many styles as you like. When you find a look you love, you can request a free estimate to build it for real.",
  },
  {
    id: "visualizer-photo-stored",
    question: "Do you store the photo I upload?",
    answer:
      "No. Your photo is used only to generate the preview and isn't permanently stored. You're welcome to use the built-in demo photo instead if you'd rather not upload your own.",
  },
  {
    id: "visualizer-accuracy",
    question: "Will my real fence look exactly like the preview?",
    answer:
      "The preview is an AI-generated illustration to help you picture styles, heights, and colors — think of it as a starting point, not a final blueprint. Your actual fence is custom-built to your property, and we'll confirm the exact materials and look when we come out for your free estimate.",
  },
  {
    id: "visualizer-styles",
    question: "What fence styles can I preview?",
    answer:
      "Cedar privacy, white vinyl, black chain link, wrought iron, ranch rail, barbed and woven wire, pipe, and ornamental metal — the same styles we install for homes, farms, and ranches across Central Kansas.",
  },
  {
    id: "visualizer-quote",
    question: "How do I get a real quote for the fence I designed?",
    answer:
      "Once you've found a style you like, request your free estimate below or call Cody at " +
      businessConfig.phone +
      ". Tell us which style you previewed and we'll measure your property and quote that exact fence — usually within one business day.",
  },
];
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  ogTitle={meta.ogTitle}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  {/* Compact title band (no hero image / CTAs) */}
  <section class="bg-foreground pb-8 pt-28 md:pb-10 md:pt-32">
    <Container>
      <nav class="mb-4 flex items-center gap-1.5 text-sm text-white/60">
        <a href="/" class="transition-colors hover:text-white">Home</a>
        <ChevronRight className="h-3.5 w-3.5" />
        <span class="text-white">Fence Visualizer</span>
      </nav>
      <span
        class="mb-3 inline-block rounded-full bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-white"
      >
        AI Fence Visualizer
      </span>
      <h1 class="max-w-3xl text-3xl font-bold text-white md:text-4xl lg:text-5xl">
        See Your New Fence Before We Build It
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-white/80">
        Upload a photo of your yard, try on different fence styles below, and
        get a free estimate for the one you love — serving Reno County and
        Central Kansas.
      </p>
    </Container>
  </section>

  {/* Embedded tool — auto-resizes to the app's reported height (no inner scroll) */}
  <section id="visualizer" class="bg-surface">
    <iframe
      id="fence-visualizer"
      src={VISUALIZER_URL}
      title="River Creek Fence — AI Fence Visualizer"
      scrolling="no"
      allow="clipboard-write; fullscreen"
      class="block w-full border-0 bg-white"
      style="height: 900px;"></iframe>

    <script is:inline define:vars={{ VISUALIZER_ORIGIN }}>
      (function () {
        var frame = document.getElementById("fence-visualizer");
        if (!frame) return;
        frame.style.height = "900px"; // fallback until the app reports its height
        window.addEventListener("message", function (e) {
          if (e.source !== frame.contentWindow) return;
          if (VISUALIZER_ORIGIN && e.origin !== VISUALIZER_ORIGIN) return;
          var d = e.data;
          if (
            d &&
            d.type === "fence-visualizer:height" &&
            typeof d.height === "number" &&
            d.height > 0
          ) {
            frame.style.height = d.height + "px";
          }
        });
      })();
    </script>
  </section>

  {/* Styles you can preview */}
  <section class="section-padding">
    <Container>
      <SectionHeading
        eyebrow="Explore"
        heading="Styles You Can Preview"
        subtitle="The visualizer covers the same fences we install across Central Kansas. Tap a style to learn more about it."
        align="center"
      />
      <div class="flex flex-wrap justify-center gap-3">
        {
          styles.map((style) => (
            <a
              href={style.href}
              class="group inline-flex items-center gap-2 rounded-full border border-border bg-white px-5 py-2.5 text-sm font-semibold text-foreground shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary-500 hover:text-primary-700"
            >
              {style.label}
              <ArrowRight className="h-4 w-4 text-primary-500 transition-transform group-hover:translate-x-0.5" />
            </a>
          ))
        }
      </div>
    </Container>
  </section>

  <FAQSection
    eyebrow="FAQ"
    heading="Fence Visualizer Questions"
    subtitle="Quick answers about how the tool works and what happens next."
    items={visualizerFaqs}
    bgColor="surface"
  />

  <CTASection
    heading="Found a Fence You Love?"
    text="Get a free, no-pressure estimate for the exact fence you designed — measured and quoted by Cody, usually within one business day."
    primaryCta={{ label: "Get a Free Quote", href: "#quote" }}
    secondaryCta={{ label: "Browse Fence Types", href: "/services" }}
  />

  <QuoteSection id="quote" />
</Layout>
