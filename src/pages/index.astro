---
import { ArrowRight } from "lucide-react";
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/sections/Hero.astro";
import InfoBar from "@/components/layout/InfoBar.astro";
import SplitSection from "@/components/sections/SplitSection.astro";
import ServiceGrid from "@/components/sections/ServiceGrid.astro";
import ProcessGrid from "@/components/sections/ProcessGrid.astro";
import ReviewsGrid from "@/components/sections/ReviewsGrid.astro";
import FAQSection from "@/components/sections/FAQSection.astro";
import CTASection from "@/components/sections/CTASection.astro";
import ServiceAreasSection from "@/components/sections/ServiceAreasSection.astro";
import QuoteSection from "@/components/sections/QuoteSection.astro";
import ChecklistGrid from "@/components/sections/ChecklistGrid.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import { businessConfig } from "@/config/business";
import { homepageContent } from "@/config/homepage";
import { homepageFaqKeys } from "@/config/faqs";
import { featuredReviews } from "@/config/reviews";
import { imageManifest } from "@/config/images";

const content = homepageContent;
const title = `${siteConfig.name} | ${siteConfig.tagline}`;
const heroPreload = imageManifest["hero-home"]?.src;
const phoneCta = {
  label: `Call ${businessConfig.phone}`,
  href: `tel:${businessConfig.phoneRaw}`,
};
---

<Layout
  title={title}
  description={siteConfig.description}
  canonical={siteConfig.url}
  ogTitle={title}
  preloadImage={heroPreload}
>
  <Hero />
  <InfoBar />

  {/* About preview */}
  <SplitSection
    imageKey={content.aboutPreview.image}
    imagePosition="right"
    badge={content.aboutPreview.badge}
    imageAspect="4/5"
  >
    <SectionHeading
      eyebrow={content.aboutPreview.eyebrow}
      heading={content.aboutPreview.heading}
    />
    <p class="mb-6 text-base leading-relaxed text-muted md:text-lg">
      {content.aboutPreview.paragraph}
    </p>
    <div class="mb-8 space-y-4">
      {
        content.aboutPreview.bullets.map((bullet) => (
          <div>
            <p class="font-semibold text-foreground">{bullet.title}</p>
            <p class="mt-1 text-sm text-muted">{bullet.description}</p>
          </div>
        ))
      }
    </div>
    <div class="flex flex-wrap gap-4">
      <Button href="/contact">
        Get a Free Quote
        <ArrowRight slot="icon" className="h-5 w-5" />
      </Button>
      <Button href="/about" variant="outline">About River Creek</Button>
    </div>
  </SplitSection>

  {/* Services */}
  <ServiceGrid limit={6} bgColor="surface" />

  {/* Standards */}
  <SplitSection
    imageKey={content.standards.image}
    imagePosition="left"
    badge={content.standards.badge}
    imageAspect="4/5"
  >
    <SectionHeading
      eyebrow={content.standards.eyebrow}
      heading={content.standards.heading}
    />
    {
      content.standards.paragraphs.map((p) => (
        <p class="mb-4 text-base leading-relaxed text-muted md:text-lg">{p}</p>
      ))
    }
    <ChecklistGrid items={content.standards.checklist} columns={2} class="mt-8" />
  </SplitSection>

  {/* Process */}
  <ProcessGrid
    eyebrow={content.process.eyebrow}
    heading={content.process.heading}
    subtitle={content.process.subtitle}
    bgColor="surface"
    primaryCta={{ label: "Get a Free Quote", href: "/contact" }}
    secondaryCta={phoneCta}
  />

  {/* Reviews */}
  <ReviewsGrid
    items={featuredReviews}
    eyebrow={content.testimonials.eyebrow}
    heading={content.testimonials.heading}
    subtitle={content.testimonials.subtitle}
    bgColor="white"
  />

  {/* Service Areas */}
  <ServiceAreasSection />

  {/* FAQ */}
  <FAQSection
    id="faq"
    eyebrow={content.faq.eyebrow}
    heading={content.faq.heading}
    subtitle={content.faq.subtitle}
    faqKeys={homepageFaqKeys}
  />

  {/* CTA */}
  <CTASection
    heading={content.cta.heading}
    text={content.cta.text}
    primaryCta={content.cta.primaryCta}
    secondaryCta={content.cta.secondaryCta}
  />

  <QuoteSection />
</Layout>
