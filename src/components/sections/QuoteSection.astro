---
import { Phone, Mail, MapPin, Clock } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import FormEmbed from "@/components/ui/FormEmbed.astro";
import { businessConfig } from "@/config/business";

interface Props {
  id?: string;
}

const { id } = Astro.props as Props;
---

<section id={id} class="section-padding bg-surface-dark">
  <Container>
    <SectionHeading
      eyebrow="Get a Quote"
      heading="Request Your Free Estimate"
      subtitle="Fill out the form below and we'll get back to you within one business day."
      align="center"
    />

    <div class="grid gap-10 lg:grid-cols-5">
      {/* Form */}
      <div class="lg:col-span-3">
        <FormEmbed />
      </div>

      {/* Contact Details Sidebar */}
      <div class="lg:col-span-2">
        <div class="rounded-2xl bg-white p-6 shadow-card md:p-8">
          <h3 class="text-xl font-bold text-foreground">Contact Details</h3>
          <p class="mt-2 text-sm text-muted">
            Prefer to reach out directly? We&apos;re here to help.
          </p>

          <div class="mt-6 space-y-5">
            <a
              href={`tel:${businessConfig.phoneRaw}`}
              class="flex items-center gap-3 text-foreground transition-colors hover:text-primary-700"
            >
              <div
                class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50"
              >
                <Phone className="h-5 w-5 text-primary-500" />
              </div>
              <div>
                <p
                  class="text-xs font-medium uppercase tracking-wider text-muted"
                >
                  Phone
                </p>
                <p class="font-semibold">{businessConfig.phone}</p>
              </div>
            </a>

            <a
              href={`mailto:${businessConfig.email}`}
              class="flex items-center gap-3 text-foreground transition-colors hover:text-primary-700"
            >
              <div
                class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50"
              >
                <Mail className="h-5 w-5 text-primary-500" />
              </div>
              <div>
                <p
                  class="text-xs font-medium uppercase tracking-wider text-muted"
                >
                  Email
                </p>
                <p class="font-semibold">{businessConfig.email}</p>
              </div>
            </a>

            <div class="flex items-start gap-3">
              <div
                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary-50"
              >
                <MapPin className="h-5 w-5 text-primary-500" />
              </div>
              <div>
                <p
                  class="text-xs font-medium uppercase tracking-wider text-muted"
                >
                  Address
                </p>
                <p class="font-semibold">{businessConfig.address.full}</p>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <div
                class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50"
              >
                <Clock className="h-5 w-5 text-primary-500" />
              </div>
              <div>
                <p
                  class="text-xs font-medium uppercase tracking-wider text-muted"
                >
                  Hours
                </p>
                <p class="font-semibold">{businessConfig.hours.display}</p>
              </div>
            </div>
          </div>

          {
            businessConfig.serviceAreas.length > 0 && (
              <div class="mt-8 border-t border-border pt-6">
                <h4 class="text-sm font-semibold uppercase tracking-wider text-muted">
                  Service Areas
                </h4>
                <p class="mt-2 text-sm text-foreground-light">
                  {businessConfig.serviceAreas.join(", ")}
                </p>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </Container>
</section>
