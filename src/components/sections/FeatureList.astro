---
import { ArrowUpRight } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import ImageSlot from "@/components/ui/ImageSlot.astro";
import { cn } from "@/lib/utils";

interface Props {
  features: {
    title: string;
    description: string;
    imageKey?: string;
    /** Optional internal link rendered as a "{ctaLabel} →" under the text. */
    href?: string;
    ctaLabel?: string;
  }[];
  eyebrow?: string;
  heading?: string;
  subtitle?: string;
  bgColor?: "white" | "surface";
  class?: string;
}

const {
  features,
  eyebrow,
  heading,
  subtitle,
  bgColor = "white",
  class: className,
} = Astro.props as Props;
---

<section
  class={cn(
    "section-padding",
    bgColor === "surface" && "bg-surface",
    className,
  )}
>
  <Container>
    {
      heading && (
        <SectionHeading
          eyebrow={eyebrow}
          heading={heading}
          subtitle={subtitle}
          align="center"
        />
      )
    }

    <div class="space-y-16">
      {
        features.map((feature, i) => (
          <div
            class={cn(
              "grid items-center gap-10 lg:grid-cols-2 lg:gap-16",
              i % 2 === 1 && "lg:[&>*:first-child]:order-2",
            )}
          >
            <div>
              <h3 class="text-2xl font-bold text-foreground md:text-3xl">
                {feature.title}
              </h3>
              <p class="mt-4 text-base leading-relaxed text-muted md:text-lg">
                {feature.description}
              </p>
              {feature.href && (
                <a
                  href={feature.href}
                  class="group mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-primary-700 transition-colors hover:text-primary-800"
                >
                  {feature.ctaLabel ?? "Learn more"}
                  <ArrowUpRight className="h-4 w-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
                </a>
              )}
            </div>
            {feature.imageKey && (
              <ImageSlot
                imageKey={feature.imageKey}
                aspectRatio="16/10"
                class="rounded-2xl"
                sizes="(max-width: 1024px) 100vw, 50vw"
              />
            )}
          </div>
        ))
      }
    </div>
  </Container>
</section>
