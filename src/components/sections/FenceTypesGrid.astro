---
import { ArrowRight } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Button from "@/components/ui/Button.astro";
import FenceTypeTile from "@/components/ui/FenceTypeTile.astro";
import { homepageContent } from "@/config/homepage";

const { fenceTypes } = homepageContent;
---

<section class="section-padding">
  <Container>
    <SectionHeading
      eyebrow={fenceTypes.eyebrow}
      heading={fenceTypes.heading}
      subtitle={fenceTypes.subtitle}
      align="center"
    />

    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 sm:gap-5 lg:grid-cols-5">
      {
        fenceTypes.items.map((type) => (
          <FenceTypeTile
            href={`/fence-types/${type.slug}`}
            label={type.label}
            imageKey={type.imageKey}
            icon={type.icon}
          />
        ))
      }
    </div>

    <div class="mt-12 flex justify-center">
      <Button href="/services" variant="outline" size="lg">
        See All Services
        <ArrowRight slot="icon" className="h-5 w-5" />
      </Button>
    </div>
  </Container>
</section>
