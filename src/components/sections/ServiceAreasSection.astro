---
import { MapPin, ChevronRight } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import MapEmbed from "@/components/ui/MapEmbed.astro";
import { businessConfig } from "@/config/business";
import { cn } from "@/lib/utils";

interface Props {
  class?: string;
}

const { class: className } = Astro.props as Props;
const cities = businessConfig.serviceAreaCities;
---

<section class={cn("section-padding bg-primary-800", className)}>
  <Container>
    {/* Header */}
    <div class="mb-12 text-center">
      <SectionHeading
        eyebrow="Where We Work"
        heading={businessConfig.serviceAreasHeading}
        subtitle={businessConfig.serviceAreasSubtitle}
        align="center"
        light
      />
    </div>

    {/* Content Grid */}
    <div class="grid items-start gap-10 lg:grid-cols-2">
      {/* Cities List */}
      <div class="rounded-2xl bg-white/10 p-6 backdrop-blur-sm md:p-8">
        <div class="mb-6 flex items-center gap-3">
          <div
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500"
          >
            <MapPin className="h-5 w-5 text-white" />
          </div>
          <h3 class="text-lg font-bold text-white">Our Service Areas</h3>
        </div>

        <div class="grid grid-cols-2 gap-2">
          {
            cities.map((city) => (
              <div>
                {city.href ? (
                  <a
                    href={city.href}
                    class="flex items-center justify-between rounded-lg bg-white/5 px-4 py-3 text-sm text-white transition-colors hover:bg-white/15"
                  >
                    <span>{city.name}</span>
                    <ChevronRight className="h-4 w-4 text-white/40" />
                  </a>
                ) : (
                  <div class="flex items-center justify-between rounded-lg bg-white/5 px-4 py-3 text-sm text-white">
                    <span>{city.name}</span>
                    <ChevronRight className="h-4 w-4 text-white/40" />
                  </div>
                )}
              </div>
            ))
          }
        </div>

        <p class="mt-6 text-sm text-white/80">
          Don&apos;t see your area?{" "}
          <a
            href="/contact"
            class="font-medium text-white underline transition-colors hover:text-primary-100"
          >
            Contact us
          </a>{" "}
          &mdash; we may still be able to help.
        </p>
      </div>

      {/* Map Embed */}
      <div class="overflow-hidden rounded-2xl shadow-card-hover">
        <MapEmbed class="h-[400px] w-full lg:h-full lg:min-h-[480px]" />
      </div>
    </div>
  </Container>
</section>
