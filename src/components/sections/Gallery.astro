---
import { Image, getImage } from "astro:assets";
import Container from "@/components/ui/Container.astro";
import { stock } from "@/config/images";
import { cn } from "@/lib/utils";

interface Props {
  /** Stock image numbers to show (defaults to all 85). */
  imageNumbers?: number[];
  class?: string;
}

const { imageNumbers, class: className } = Astro.props as Props;
const numbers = imageNumbers ?? Array.from({ length: 85 }, (_, i) => i + 1);

const items = await Promise.all(
  numbers.map(async (n) => {
    const meta = stock[n];
    const alt = `Fence project completed by River Creek Fence in Central Kansas (#${n})`;
    // Optimized full-size URL for the lightbox (far smaller than the 1920px source).
    const full = await getImage({ src: meta, width: 1600, format: "webp" });
    return { meta, alt, full: full.src };
  }),
);

// Only the lightbox needs data across the inline-script boundary.
const lightboxImages = items.map((it) => ({ alt: it.alt, full: it.full }));
---

<section class={cn("section-padding", className)}>
  <Container>
    <div
      class="columns-2 gap-3 md:columns-3 md:gap-4 lg:columns-4 [&>*]:mb-3 md:[&>*]:mb-4"
    >
      {
        items.map((item, i) => (
          <button
            type="button"
            class="group block w-full overflow-hidden rounded-xl border border-border focus:outline-none focus:ring-2 focus:ring-primary-500"
            data-gallery-item
            data-index={i}
            aria-label={`View ${item.alt}`}
          >
            <Image
              src={item.meta}
              alt={item.alt}
              widths={[300, 500, 700]}
              sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
              format="webp"
              loading="lazy"
              decoding="async"
              class="h-auto w-full transition-transform duration-300 group-hover:scale-105"
            />
          </button>
        ))
      }
    </div>
  </Container>

  {/* Lightbox */}
  <div
    id="gallery-lightbox"
    class="fixed inset-0 z-[10000] hidden items-center justify-center bg-black/90 p-4"
    role="dialog"
    aria-modal="true"
    aria-label="Image viewer"
  >
    <button
      type="button"
      data-gallery-close
      class="absolute right-4 top-4 flex h-11 w-11 items-center justify-center rounded-full bg-white/10 text-2xl text-white transition-colors hover:bg-white/20"
      aria-label="Close"
    >
      &times;
    </button>
    <button
      type="button"
      data-gallery-prev
      class="absolute left-3 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-3xl text-white transition-colors hover:bg-white/20 md:left-6"
      aria-label="Previous"
    >
      &#8249;
    </button>
    <img
      id="gallery-lightbox-img"
      src=""
      alt=""
      class="max-h-[88vh] max-w-[92vw] rounded-lg object-contain"
    />
    <button
      type="button"
      data-gallery-next
      class="absolute right-3 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-3xl text-white transition-colors hover:bg-white/20 md:right-6"
      aria-label="Next"
    >
      &#8250;
    </button>
  </div>
</section>

<script
  is:inline
  define:vars={{ images: lightboxImages }}
>
  (function () {
    const lightbox = document.getElementById("gallery-lightbox");
    const lbImg = document.getElementById("gallery-lightbox-img");
    if (!lightbox || !lbImg) return;
    let current = 0;

    function show(i) {
      current = (i + images.length) % images.length;
      lbImg.src = images[current].full;
      lbImg.alt = images[current].alt;
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      document.body.style.overflow = "hidden";
    }
    function close() {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      document.body.style.overflow = "";
    }

    document.querySelectorAll("[data-gallery-item]").forEach((el) => {
      el.addEventListener("click", () =>
        show(parseInt(el.getAttribute("data-index"))),
      );
    });
    lightbox
      .querySelector("[data-gallery-close]")
      .addEventListener("click", close);
    lightbox
      .querySelector("[data-gallery-prev]")
      .addEventListener("click", (e) => {
        e.stopPropagation();
        show(current - 1);
      });
    lightbox
      .querySelector("[data-gallery-next]")
      .addEventListener("click", (e) => {
        e.stopPropagation();
        show(current + 1);
      });
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener("keydown", (e) => {
      if (lightbox.classList.contains("hidden")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") show(current - 1);
      if (e.key === "ArrowRight") show(current + 1);
    });
  })();
</script>
