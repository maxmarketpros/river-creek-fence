---
import { ArrowRight, Sparkles, Check } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import { homepageContent } from "@/config/homepage";

const { visualizer } = homepageContent;
---

<section class="section-padding bg-surface">
  <Container>
    <div
      class="relative overflow-hidden rounded-3xl bg-foreground px-6 py-14 text-center shadow-card-hover md:px-12 md:py-20"
    >
      {/* Decorative lime glows + faint oversized icon */}
      <div
        class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-primary-500/20 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute -bottom-20 -left-20 h-64 w-64 rounded-full bg-primary-500/10 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <Sparkles
        className="pointer-events-none absolute -right-6 bottom-2 h-44 w-44 text-white/5"
        aria-hidden="true"
      />

      <div class="relative mx-auto max-w-2xl">
        <div
          class="mx-auto flex h-20 w-20 items-center justify-center rounded-2xl bg-primary-500 shadow-badge"
        >
          <Sparkles className="h-10 w-10 text-black" strokeWidth={2} />
        </div>

        <span
          class="mt-6 inline-flex items-center gap-1.5 rounded-full bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-primary-400"
        >
          <Sparkles className="h-3.5 w-3.5" />
          {visualizer.eyebrow}
        </span>

        <h2 class="mt-4 text-3xl font-bold tracking-tight text-white md:text-4xl">
          {visualizer.heading.line1}
          <span class="block text-primary-400">{visualizer.heading.line2}</span>
        </h2>

        <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-white/85">
          {visualizer.text}
        </p>

        <div
          class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-6"
        >
          {
            visualizer.points.map((point) => (
              <span class="inline-flex items-center gap-2 text-sm font-medium text-white/90">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-primary-500">
                  <Check className="h-3 w-3 text-black" strokeWidth={3} />
                </span>
                {point}
              </span>
            ))
          }
        </div>

        <div class="mt-10">
          <Button href={visualizer.cta.href} size="lg">
            {visualizer.cta.label}
            <ArrowRight slot="icon" className="h-5 w-5" />
          </Button>
        </div>
      </div>
    </div>
  </Container>
</section>
