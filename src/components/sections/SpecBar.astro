---
import Container from "@/components/ui/Container.astro";
import IconTile from "@/components/ui/IconTile.astro";
import { cn } from "@/lib/utils";
import type { SpecItem } from "@/types";

interface Props {
  items: SpecItem[];
  class?: string;
}

const { items, class: className } = Astro.props as Props;
---

<section class={cn("border-b border-border bg-surface py-8 md:py-10", className)}>
  <Container>
    <div
      class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-border bg-border shadow-card md:grid-cols-4"
    >
      {
        items.map((item) => (
          <div class="flex items-center gap-3 bg-white p-4 sm:gap-4 sm:p-5 md:p-6">
            <IconTile icon={item.icon} variant="lime" size="sm" />
            <div>
              <div class="text-sm font-bold leading-snug text-foreground sm:text-base md:text-lg">
                {item.value}
              </div>
              <div class="mt-0.5 text-[11px] font-medium uppercase tracking-wide text-muted sm:text-xs">
                {item.label}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
