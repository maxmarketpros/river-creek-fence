---
import { ArrowRight, Phone } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import StatItem from "@/components/ui/StatItem.astro";
import ImageSlot from "@/components/ui/ImageSlot.astro";
import GoogleReviewBadge from "@/components/ui/GoogleReviewBadge.astro";
import { homepageContent } from "@/config/homepage";
import { heroStats } from "@/config/stats";

const { hero } = homepageContent;
---

<section class="relative flex min-h-screen items-center">
  {/* Background Image */}
  <ImageSlot
    imageKey="hero-home"
    fill
    priority
    class="absolute inset-0 z-0"
    overlayClassName="bg-black/55"
    sizes="100vw"
  />

  {/* Content */}
  <Container class="relative z-10 w-full min-w-0 py-32 text-center">
    <span
      class="mb-4 inline-block rounded-full bg-white/10 px-5 py-2 text-xs font-semibold uppercase tracking-widest text-white backdrop-blur-sm"
    >
      Fence Company in Haven, KS · Serving Central Kansas
    </span>

    <h1
      class="mx-auto max-w-4xl text-4xl font-bold leading-tight text-white md:text-5xl lg:text-6xl"
    >
      {hero.heading.main}
      <span class="block">{hero.heading.location}</span>
    </h1>

    <p
      class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/80 md:text-xl"
    >
      {hero.subtitle}
    </p>

    <div
      class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
    >
      <Button href={hero.primaryCta.href} size="lg">
        {hero.primaryCta.label}
        <ArrowRight slot="icon" className="h-5 w-5" />
      </Button>
      <Button
        href={hero.secondaryCta.href}
        variant="outline"
        size="lg"
        class="border-white text-white hover:bg-white hover:text-foreground"
      >
        {hero.secondaryCta.label}
        <Phone slot="icon" className="h-5 w-5" />
      </Button>
    </div>

    {/* Google rating badge */}
    <div class="mt-8 flex justify-center">
      <GoogleReviewBadge variant="dark" />
    </div>

    {/* Stats Row */}
    <div
      class="mx-auto mt-16 flex max-w-lg items-center justify-center gap-4 sm:gap-8 md:gap-12"
    >
      {
        heroStats.map((stat, i) => (
          <div class="flex items-center gap-4 sm:gap-8">
            <StatItem value={stat.value} label={stat.label} light />
            {i < heroStats.length - 1 && (
              <div class="h-10 w-px bg-white/20" />
            )}
          </div>
        ))
      }
    </div>
  </Container>
</section>
