---
import { Star } from "lucide-react";
import { businessConfig } from "@/config/business";
import { cn } from "@/lib/utils";

interface Props {
  variant?: "dark" | "light";
  class?: string;
}

const { variant = "dark", class: className } = Astro.props as Props;
// "dark" = sits on a dark/photo background (white text)
const isDark = variant === "dark";
---

<a
  href={businessConfig.googleReviewUrl}
  target="_blank"
  rel="noopener"
  aria-label="5.0 Google Reviews — read our reviews on Google"
  class={cn(
    "inline-flex items-center gap-3 rounded-full border px-4 py-2 backdrop-blur-sm transition-colors",
    isDark
      ? "border-white/20 bg-white/10 text-white hover:bg-white/15"
      : "border-border bg-white text-foreground shadow-card hover:bg-surface",
    className,
  )}
>
  {/* Google G */}
  <svg class="h-5 w-5 shrink-0" viewBox="0 0 48 48" aria-hidden="true">
    <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"></path>
    <path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"></path>
    <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0124 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"></path>
    <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 01-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"></path>
  </svg>
  <span class="flex items-center gap-2">
    <span class="text-sm font-bold">5.0</span>
    <span class="flex">
      {
        Array.from({ length: 5 }).map(() => (
          <Star className="h-4 w-4 fill-secondary-400 text-secondary-400" />
        ))
      }
    </span>
    <span class={cn("text-sm font-medium", isDark ? "text-white/80" : "text-muted")}>
      Google Reviews
    </span>
  </span>
</a>
