---
import { cn } from "@/lib/utils";

interface Props {
  value: string;
  label: string;
  position?: "bottom-right" | "bottom-left" | "top-right" | "top-left";
  class?: string;
}

const positionClasses = {
  "bottom-right": "-bottom-4 -right-4 md:bottom-4 md:right-4",
  "bottom-left": "-bottom-4 -left-4 md:bottom-4 md:left-4",
  "top-right": "-top-4 -right-4 md:top-4 md:right-4",
  "top-left": "-top-4 -left-4 md:top-4 md:left-4",
};

const {
  value,
  label,
  position = "bottom-right",
  class: className,
} = Astro.props as Props;
---

<div
  class={cn(
    "absolute z-10 flex items-center gap-3 rounded-xl bg-white px-5 py-3 shadow-badge",
    positionClasses[position],
    className,
  )}
>
  <span
    class="flex h-12 min-w-[3rem] items-center justify-center whitespace-nowrap rounded-full bg-primary-500 px-3 text-base font-bold leading-none text-black"
  >
    {value}
  </span>
  <p class="whitespace-nowrap text-sm font-bold text-foreground">{label}</p>
</div>
