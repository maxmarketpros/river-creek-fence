---
import { cn } from "@/lib/utils";

interface Props {
  value: string;
  label: string;
  light?: boolean;
  class?: string;
}

const { value, label, light = false, class: className } = Astro.props as Props;
---

<div class={cn("text-center", className)}>
  <p
    class={cn(
      "text-3xl font-bold md:text-4xl",
      light ? "text-white" : "text-primary-700",
    )}
  >
    {value}
  </p>
  <p
    class={cn(
      "mt-1 text-xs font-semibold uppercase tracking-widest",
      light ? "text-white/70" : "text-muted",
    )}
  >
    {label}
  </p>
</div>
