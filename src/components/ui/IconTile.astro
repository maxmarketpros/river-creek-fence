---
import * as LucideIcons from "lucide-react";
import { cn } from "@/lib/utils";

interface Props {
  /** Lucide icon name; falls back to Star if unknown. */
  icon: string;
  /** lime = lime tile + charcoal icon · charcoal = charcoal tile + lime icon. */
  variant?: "lime" | "charcoal";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const {
  icon,
  variant = "lime",
  size = "md",
  class: className,
} = Astro.props as Props;

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const IconComponent = (LucideIcons as any)[icon] || LucideIcons.Star;

const tile = {
  sm: "h-11 w-11 rounded-xl",
  md: "h-14 w-14 rounded-2xl",
  lg: "h-16 w-16 rounded-2xl",
};
const glyph = {
  sm: "h-5 w-5",
  md: "h-7 w-7",
  lg: "h-8 w-8",
};
---

<div
  class={cn(
    "inline-flex shrink-0 items-center justify-center shadow-sm",
    tile[size],
    variant === "lime"
      ? "bg-primary-500 text-black"
      : "bg-foreground text-primary-400",
    className,
  )}
>
  <IconComponent className={glyph[size]} strokeWidth={2.25} />
</div>
