---
import { FileText } from "lucide-react";
import { businessConfig } from "@/config/business";
import { cn } from "@/lib/utils";

interface Props {
  class?: string;
  height?: string;
}

const { class: className, height } = Astro.props as Props;
const embedUrl = businessConfig.formEmbedUrl;
const embedHeight = height || businessConfig.formEmbedHeight;
const formId = businessConfig.formEmbedId;
---

{
  embedUrl ? (
    <>
      <iframe
        src={embedUrl}
        title="Request a free fence estimate"
        id={formId}
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-activation-type="alwaysActivated"
        data-deactivation-type="neverDeactivate"
        data-form-name="River Creek Fence — Request a Quote"
        data-height={parseInt(embedHeight)}
        data-layout-iframe-id={formId}
        data-form-id={businessConfig.formEmbedId.replace("inline-", "")}
        class={cn("w-full border-0 rounded-xl bg-white", className)}
        style={`height: ${embedHeight}`}
      />
      <script is:inline src="https://link.msgsndr.com/js/form_embed.js" />
    </>
  ) : (
    <div
      class={cn(
        "flex flex-col items-center justify-center gap-4 rounded-xl border-2 border-dashed border-border bg-surface",
        className,
      )}
      style={`height: ${embedHeight}`}
    >
      <div class="flex h-16 w-16 items-center justify-center rounded-full bg-primary-50">
        <FileText className="h-8 w-8 text-primary-700" />
      </div>
      <p class="text-sm font-semibold text-foreground">Quote form loading…</p>
    </div>
  )
}
