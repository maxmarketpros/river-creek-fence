---
import { ArrowRight } from "lucide-react";
import * as LucideIcons from "lucide-react";
import ImageSlot from "./ImageSlot.astro";
import { cn } from "@/lib/utils";

interface Props {
  href: string;
  label: string;
  imageKey: string;
  /** Optional Lucide icon name for the chip over the image. */
  icon?: string;
  class?: string;
}

const { href, label, imageKey, icon, class: className } =
  Astro.props as Props;
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const IconComponent = icon ? (LucideIcons as any)[icon] || LucideIcons.Fence : null;
---

<a
  href={href}
  class={cn(
    "group relative block overflow-hidden rounded-2xl shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2",
    className,
  )}
>
  <ImageSlot
    imageKey={imageKey}
    aspectRatio="4/5"
    sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 20vw"
    class="rounded-none transition-transform duration-500 group-hover:scale-105"
  />

  {/* Gradient overlay keeps the label legible over any photo */}
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent"
  >
  </div>

  {
    IconComponent && (
      <div class="absolute left-3 top-3 flex h-9 w-9 items-center justify-center rounded-xl bg-black/55 backdrop-blur-sm">
        <IconComponent className="h-4 w-4 text-primary-400" />
      </div>
    )
  }

  <div class="absolute inset-x-0 bottom-0 flex items-end justify-between gap-2 p-4">
    <h3 class="text-base font-bold leading-tight text-white sm:text-lg">
      {label}
    </h3>
    <ArrowRight
      className="h-5 w-5 shrink-0 text-primary-400 transition-transform duration-300 group-hover:translate-x-1"
    />
  </div>
</a>
