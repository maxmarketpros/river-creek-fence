---
import { cn } from "@/lib/utils";

interface Props {
  eyebrow?: string;
  heading: string;
  subtitle?: string;
  align?: "left" | "center";
  light?: boolean;
  class?: string;
}

const {
  eyebrow,
  heading,
  subtitle,
  align = "left",
  light = false,
  class: className,
} = Astro.props as Props;
---

<div
  class={cn(
    "mb-10 md:mb-14",
    align === "center" && "text-center",
    className,
  )}
>
  {
    eyebrow && (
      <span
        class={cn(
          "mb-3 inline-block rounded-full bg-primary-100 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-primary-800",
          light && "bg-white/10 text-white",
        )}
      >
        {eyebrow}
      </span>
    )
  }
  <h2
    class={cn(
      "text-3xl font-bold tracking-tight md:text-4xl",
      light ? "text-white" : "text-foreground",
    )}
  >
    {heading}
  </h2>
  {
    subtitle && (
      <p
        class={cn(
          "mt-4 max-w-2xl text-lg leading-relaxed",
          align === "center" && "mx-auto",
          light ? "text-white/80" : "text-muted",
        )}
      >
        {subtitle}
      </p>
    )
  }
</div>
