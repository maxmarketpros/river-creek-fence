---
import { Picture } from "astro:assets";
import { imageManifest, HERO_WIDTHS } from "@/config/images";
import { cn } from "@/lib/utils";

interface Props {
  imageKey: string;
  aspectRatio?: string;
  priority?: boolean;
  sizes?: string;
  class?: string;
  fill?: boolean;
  overlayClassName?: string;
}

const {
  imageKey,
  aspectRatio,
  priority = false,
  sizes,
  class: className,
  fill = false,
  overlayClassName,
} = Astro.props as Props;

const config = imageManifest[imageKey];
if (!config) {
  // Images are bundled and resolved at build now — an unknown key is a bug,
  // so fail loudly rather than silently shipping a placeholder.
  throw new Error(`ImageSlot: unknown imageKey "${imageKey}"`);
}

const focalX = config.focalPoint?.x ?? 0.5;
const focalY = config.focalPoint?.y ?? 0.5;
const objectPosition = `${focalX * 100}% ${focalY * 100}%`;

// Full-bleed heroes get the wider ladder (and match the LCP preload widths);
// in-content images use a smaller set so we never over-fetch.
const widths = fill ? HERO_WIDTHS : [400, 640, 800, 1100];
const resolvedSizes =
  sizes ?? (fill ? "100vw" : "(min-width: 768px) 50vw, 100vw");
---

<div
  class={cn(
    fill ? "relative overflow-hidden" : "relative overflow-hidden rounded-xl",
    className,
  )}
  style={!fill && aspectRatio ? `aspect-ratio: ${aspectRatio}` : undefined}
>
  <Picture
    src={config.src}
    alt={config.alt}
    widths={widths}
    sizes={resolvedSizes}
    formats={["avif", "webp"]}
    loading={priority ? "eager" : "lazy"}
    decoding={priority ? "sync" : "async"}
    fetchpriority={priority ? "high" : undefined}
    class="absolute inset-0 h-full w-full object-cover"
    style={`object-position: ${objectPosition}`}
  />
  {overlayClassName && <div class={cn("absolute inset-0", overlayClassName)} />}
</div>
