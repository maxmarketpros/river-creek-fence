---
import { Phone, Mail, MapPin, Clock, Star } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import MapEmbed from "@/components/ui/MapEmbed.astro";
import { siteConfig } from "@/config/site";
import { businessConfig } from "@/config/business";
import { footerGroups } from "@/config/navigation";

const currentYear = new Date().getFullYear();

const socials = [
  { label: "Google Business Profile", href: siteConfig.social.google, domain: "google.com" },
  { label: "Facebook", href: siteConfig.social.facebook, domain: "facebook.com" },
  { label: "Yelp", href: siteConfig.social.yelp, domain: "yelp.com" },
  { label: "HomeAdvisor", href: siteConfig.social.homeadvisor, domain: "homeadvisor.com" },
];
---

<footer class="bg-black text-white">
  <Container>
    {/* Top: brand + contact + map */}
    <div class="grid gap-10 py-14 lg:grid-cols-3">
      {/* Brand */}
      <div>
        <a href="/" class="inline-block" aria-label="River Creek Fence — home">
          <img
            src="/images/logo-transparent.png"
            alt="River Creek Fence"
            width="500"
            height="393"
            class="h-20 w-auto"
          />
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-white/70">
          {businessConfig.positioningLine}
        </p>
        <a
          href={businessConfig.googleReviewUrl}
          target="_blank"
          rel="noopener"
          class="mt-4 inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1.5 text-sm font-semibold transition-colors hover:bg-white/15"
        >
          <span class="flex">
            {Array.from({ length: 5 }).map(() => (
              <Star className="h-4 w-4 fill-secondary-400 text-secondary-400" />
            ))}
          </span>
          5.0 on Google
        </a>

        {/* Social icons */}
        <div class="mt-5 flex items-center gap-3">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                aria-label={s.label}
                title={s.label}
                class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-primary-500"
              >
                <img
                  src={`https://www.google.com/s2/favicons?domain=${s.domain}&sz=64`}
                  alt={s.label}
                  width="20"
                  height="20"
                  loading="lazy"
                  class="h-5 w-5 rounded-sm"
                />
              </a>
            ))
          }
        </div>
      </div>

      {/* Contact */}
      <div>
        <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-primary-400">
          Get In Touch
        </h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href={`tel:${businessConfig.phoneRaw}`}
              class="flex items-center gap-3 text-white/80 transition-colors hover:text-white"
            >
              <Phone className="h-4 w-4 shrink-0 text-primary-400" />
              {businessConfig.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${businessConfig.email}`}
              class="flex items-center gap-3 text-white/80 transition-colors hover:text-white"
            >
              <Mail className="h-4 w-4 shrink-0 text-primary-400" />
              {businessConfig.email}
            </a>
          </li>
          <li>
            <span class="flex items-center gap-3 text-white/80">
              <MapPin className="h-4 w-4 shrink-0 text-primary-400" />
              {businessConfig.address.full}
            </span>
          </li>
          <li>
            <span class="flex items-center gap-3 text-white/80">
              <Clock className="h-4 w-4 shrink-0 text-primary-400" />
              {businessConfig.hours.display}
            </span>
          </li>
        </ul>
        <a
          href="/contact"
          class="mt-5 inline-flex items-center justify-center rounded-lg bg-primary-500 px-5 py-2.5 text-sm font-bold text-black transition-colors hover:bg-primary-400"
        >
          Request a Free Estimate
        </a>
      </div>

      {/* Map */}
      <div class="overflow-hidden rounded-2xl border border-white/10">
        <MapEmbed class="h-full min-h-[220px] w-full" />
      </div>
    </div>

    {/* Link columns */}
    <div class="grid gap-8 border-t border-white/10 py-12 sm:grid-cols-2 lg:grid-cols-4">
      {
        footerGroups.map((group) => (
          <div>
            <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-primary-400">
              {group.title}
            </h3>
            <ul class="space-y-2.5">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-white/70 transition-colors hover:text-primary-400"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    {/* Bottom bar */}
    <div
      class="flex flex-col items-center justify-between gap-3 border-t border-white/10 py-6 text-center md:flex-row md:text-left"
    >
      <p class="text-xs text-white/60">
        &copy; {currentYear} River Creek Fence LLC. All rights reserved.
      </p>
      <p class="text-xs text-white/60">
        Fence Company in Haven, KS · Serving Reno County & Central Kansas
      </p>
    </div>
  </Container>
</footer>
