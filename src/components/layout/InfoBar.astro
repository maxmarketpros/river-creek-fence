---
import { MapPin, Clock, Phone, Star } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import { businessConfig } from "@/config/business";
---

<div class="bg-foreground text-white">
  <Container>
    <div
      class="flex flex-col items-center justify-between gap-3 py-3 text-sm md:flex-row md:gap-6"
    >
      <div class="flex items-center gap-2">
        <MapPin className="h-4 w-4 text-primary-400" />
        <span>{businessConfig.address.full}</span>
      </div>
      <div class="hidden h-4 w-px bg-white/20 md:block"></div>
      <div class="flex items-center gap-2">
        <Clock className="h-4 w-4 text-primary-400" />
        <span>{businessConfig.hours.display}</span>
      </div>
      <div class="hidden h-4 w-px bg-white/20 md:block"></div>
      <div class="flex items-center gap-1.5">
        <Star className="h-4 w-4 fill-secondary-400 text-secondary-400" />
        <span>5.0 on Google</span>
      </div>
      <div class="hidden h-4 w-px bg-white/20 md:block"></div>
      <a
        href={`tel:${businessConfig.phoneRaw}`}
        class="flex items-center gap-2 font-semibold transition-colors hover:text-primary-400"
      >
        <Phone className="h-4 w-4 text-primary-400" />
        <span>{businessConfig.phone}</span>
      </a>
    </div>
  </Container>
</div>
